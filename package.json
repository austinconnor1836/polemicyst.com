{
  "private": true,
  "_moduleAliases": {
    "@shared": "dist/shared"
  },
  "scripts": {
    "dev": "next dev --experimental-https --hostname 0.0.0.0",
    "dev:clip-worker": "tsx watch workers/clip-metadata-worker/index.ts",
    "dev:download-worker": "tsx watch workers/video-download-worker/index.ts",
    "build": "npx prisma generate && next build",
    "build:worker": "tsc",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "backend": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "backend:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "openapi:generate": "cd android && ./gradlew openApiGenerate",
    "tokens": "node scripts/generate-tokens.mjs",
    "version:bump": "node scripts/bump-version.mjs"
  },
