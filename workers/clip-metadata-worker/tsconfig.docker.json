{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@prisma/client": ["./node_modules/@prisma/client"],
      "*": ["./node_modules/*"]
    }
  },
  "include": [
    "**/*.ts",
    "../../shared/lib/prisma.ts",
    "../../shared/lib/cost-tracking.ts",
    "../../shared/lib/job-logger.ts",
    "../../shared/lib/plans.ts",
    "../../shared/lib/training-collector.ts",
    "../../shared/lib/transcription.ts",
    "../../shared/lib/innertube.ts",
    "../../shared/lib/youtube-captions.ts",
    "../../shared/lib/scoring/**/*.ts",
    "../../shared/lib/quote-detection.ts",
    "../../shared/lib/publishing/rasterize.ts",
    "../../shared/queues/**/*.ts",
    "../../shared/util/ffmpegUtils.ts",
    "../../shared/util/thumbnailGenerator.ts",
    "../../shared/util/reactionCompose.ts",
    "../../shared/util/quoteGraphics.ts",
    "../../shared/util/quoteScreenshot.ts",
    "../../shared/util/cropDetect.ts",
    "../../shared/util/download.ts",
    "../../shared/util/auto-edit-analyzer.ts",
    "../../shared/auto-edit.ts",
    "../../shared/virality.ts"
  ],
  "exclude": ["node_modules", "scripts"]
}
