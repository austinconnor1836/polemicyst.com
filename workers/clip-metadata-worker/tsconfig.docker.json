{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@prisma/client": ["./node_modules/@prisma/client"],
      "*": ["./node_modules/*"]
    }
  },
  "include": ["**/*.ts", "../../shared/**/*.ts"],
  "exclude": ["node_modules", "scripts", "../../shared/lib/auth.ts", "../../shared/lib/auth-helpers.ts"]
}
