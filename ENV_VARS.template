# Local environment variables (template)
#
# Create two files locally (NOT committed):
# - .env
# - .env.local
#
# Then paste the needed variables from below and fill in secrets.
#
# --- Database (local dev) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clips-genie
#
# --- Redis (local dev) ---
REDIS_HOST=localhost
#
# --- Optional: AWS (only needed for S3 upload/download flows) ---
AWS_REGION=us-east-1
# S3 bucket used by uploads/feeds (set per environment)
S3_BUCKET=
# Some parts of the codebase read S3_REGION (fallbacks vary), so set both for consistency.
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Set to 'true' to use S3 Transfer Acceleration (bucket must have it enabled)
S3_TRANSFER_ACCELERATION=false
#
# --- Optional: model APIs (only if using external scoring/models) ---
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=gemini
# Acts as the fallback default provider; users can set their own preference in-app.
GEMINI_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# --- Auth secrets ---
# NextAuth JWT secret (used for encoding/decoding session JWTs, including mobile Bearer tokens)
NEXTAUTH_SECRET=

# --- Mobile auth ---
# Apple Sign-In: bundle ID used as audience for identity token verification
APPLE_CLIENT_ID=com.polemicyst.app
# Google iOS OAuth client ID (created in Google Cloud Console for iOS bundle)
GOOGLE_IOS_CLIENT_ID=

# --- Optional: auth debug logging (DANGER: may log OAuth tokens if enabled) ---
# Default is off. Only set this temporarily for local debugging and avoid sharing logs.
NEXTAUTH_DEBUG=false

# --- Optional: auth allowlist (lockdown mode) ---
# When enabled, only the allowed emails/providers can sign in.
AUTH_ALLOWLIST_ENABLED=true
# Comma-separated list of allowed emails (lower/upper case ok).
AUTH_ALLOWED_EMAILS=
# Comma-separated list of allowed providers (default used in code: google).
AUTH_ALLOWED_PROVIDERS=google

# --- Admin (cost dashboard access) ---
ADMIN_EMAIL=aconnor731@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=aconnor731@gmail.com

# --- Stripe (billing & subscriptions) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
#
# Per-plan, per-interval price IDs (Stripe dashboard → Products → Pricing).
# Set both MONTHLY and ANNUAL for each paid tier to enable annual billing.
# Creator tier
STRIPE_CREATOR_MONTHLY_PRICE_ID=
STRIPE_CREATOR_ANNUAL_PRICE_ID=
# Pro tier
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
# Agency tier
STRIPE_AGENCY_MONTHLY_PRICE_ID=
STRIPE_AGENCY_ANNUAL_PRICE_ID=
#
# DEPRECATED — legacy single-price vars (still read as fallback for existing subscribers).
# Prefer the per-interval vars above for new deployments.
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# --- Rate limiting (Upstash Redis) ---
# When both are set, the rate limiter uses Upstash (shared across instances).
# When unset, falls back to an in-memory per-process limiter — fine for dev,
# NOT safe in multi-instance production deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Error tracking (Sentry) ---
# DSN for client-side (browser) Sentry. Safe to expose — Sentry DSNs are public by design.
# When unset, Sentry.init is a runtime no-op and no events are reported.
NEXT_PUBLIC_SENTRY_DSN=
# DSN for server-side (Next.js server runtime + workers) Sentry. Falls back to NEXT_PUBLIC_SENTRY_DSN
# in the Next.js config; workers read SENTRY_DSN directly. Same project as the client DSN is fine.
SENTRY_DSN=
# Auth token used by the build-time Sentry webpack plugin to upload source maps to Sentry.
# Required only for production builds where you want symbolicated stack traces. Get from
# https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/. When unset,
# source-map upload is skipped so local/dev builds never fail on missing credentials.
SENTRY_AUTH_TOKEN=
# Sentry org + project slugs used by the webpack plugin. Required only when SENTRY_AUTH_TOKEN is set.
SENTRY_ORG=
SENTRY_PROJECT=

# --- iOS Crashlytics (Firebase) ---
# The iOS app loads `GoogleService-Info.plist` from the app bundle at startup. The file
# is NOT committed to the repo — download it from the Firebase console for the
# `com.clipfire.app` iOS app and place it at `ios/Supporting/GoogleService-Info.plist` for
# local builds, and ship it via CI secrets (base64-encoded) for TestFlight/App Store builds.
# When the plist is absent, FirebaseApp.configure() logs a warning and Crashlytics stays disabled —
# the app still launches and runs normally.
