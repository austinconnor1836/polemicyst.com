// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String               @id @default(uuid())
  name                     String?
  email                    String?              @unique
  emailVerified            DateTime?
  stripeCustomerId         String?
  subscriptionPlan         String               @default("free") // 'free', 'pro', etc.
  image                    String?
  defaultLLMProvider       String               @default("ollama")
  defaultPublishPlatforms  Json?                // string[] of platform identifiers for social posting defaults
  accounts                 Account[]
  sessions                 Session[]
  videos                   Video[]
  templatePreferences      TemplatePreferences?
  clipCropTemplates        ClipCropTemplate[]
  videoFeeds               VideoFeed[]
  feedVideos               FeedVideo[]
  brands                   Brand[]
  automationRule           AutomationRule?
  publications             Publication[]
  publishingAccounts       PublishingAccount[]
  uploadLogs               UploadLog[]
  socialPosts              SocialPost[]
  compositions             Composition[]
}

model TemplatePreferences {
  id                String @id @default(uuid())
  userId            String @unique
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  facebookTemplate  String
  instagramTemplate String
  youtubeTemplate   String
  sharedPostscript  String
}

model Video {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName            String?
  s3Url               String?
  s3Key               String?
  videoTitle          String
  sharedDescription   String
  facebookTemplate    String
  instagramTemplate   String
  youtubeTemplate     String
  blueskyTemplate     String
  twitterTemplate     String
  transcript          String?
  approvedForSplicing Boolean  @default(false)
  trimStartS          Float?
  trimEndS            Float?
  createdAt           DateTime @default(now())

  // Clip relationship (self-referencing)
  sourceVideo   Video?  @relation("ClipSource", fields: [sourceVideoId], references: [id])
  sourceVideoId String?
  generatedClips Video[] @relation("ClipSource")

  // Link back to the source FeedVideo that spawned this clip
  feedVideo   FeedVideo? @relation("FeedVideoClips", fields: [feedVideoId], references: [id])
  feedVideoId String?

  // Added relation for pipeline segments
  segments        Segment[]
  clipSourceFeedVideo FeedVideo? @relation("FeedVideoClipSource")
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoFeeds VideoFeed[]

  @@index([userId])
  @@map("brands")
}

model VideoFeed {
  id              String    @id @default(cuid())
  name            String
  sourceUrl       String
  sourceType      String
  pollingInterval Int
  lastCheckedAt   DateTime?
  lastVideoId     String?
  autoGenerateClips Boolean   @default(false)
  viralitySettings  Json?
  youtubeChannelId    String?
  youtubeChannelTitle String?
  youtubeChannelThumb String?
  brandId         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  feedVideos FeedVideo[]

  @@index([brandId])
  @@map("connected_accounts")
}

model FeedVideo {
  id                    String    @id @default(uuid())
  feedId                String
  feed                  VideoFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  videoId               String
  clipSourceVideoId     String?   @unique
  clipSourceVideo       Video?    @relation("FeedVideoClipSource", fields: [clipSourceVideoId], references: [id], onDelete: SetNull)
  title                 String
  thumbnailUrl          String?
  s3Url                 String
  status                String    @default("ready") // pending | ready | failed
  transcript            String?
  transcriptJson        Json?
  transcriptSource      String?   // whisper | youtube-manual | youtube-auto
  speakerTranscriptJson Json?
  clipGenerationStatus  String    @default("idle") // idle | queued | processing | completed | failed
  clipGenerationError   String?
  createdAt             DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  generatedClips  Video[] @relation("FeedVideoClips")
  jobLogs         JobLog[]
  truthAnalyses   TruthAnalysis[]
  analysisChats   AnalysisChat[]

  @@unique([feedId, videoId])
  @@map("account_videos")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  expires_at        Int?
  id_token          String?
  refresh_token     String?
  scope             String?
  session_state     String?
  token_type        String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId]) // Ensures unique provider+accountId
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Segment {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tStartS   Float
  tEndS     Float
  features  Json
  llmNotes  Json?
  score     Float
  selected  Boolean  @default(false)
  clips     Clip[]
  rhetoricLabels SegmentRhetoricLabel[]

  @@index([videoId])
  @@index([score])
}

model Clip {
  id          String   @id @default(cuid())
  segmentId   String
  segment     Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  variant     String
  s3Key       String?
  title       String?
  description String?
  hashtags    String?
  publishMap  Json?
  metrics     Metric[]

  @@index([segmentId])
}

model Metric {
  id          String   @id @default(cuid())
  clipId      String
  clip        Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  platform    String
  impressions Int
  views3s     Int
  views30s    Int
  avgWatchS   Float
  ctr         Float
  collectedAt DateTime @default(now())

  @@index([clipId])
}

model SegmentRhetoricLabel {
  id        String   @id @default(uuid())
  segmentId String
  segment   Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  label     Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([segmentId])
}

model CostEvent {
  id               String   @id @default(cuid())
  userId           String
  jobId            String   // feedVideoId — groups events per video run
  stage            String   // download | transcription | llm_scoring | ffmpeg_render | s3_upload
  provider         String?  // gemini | ollama | whisper | s3 | ffmpeg
  model            String?
  inputTokens      Int?
  outputTokens     Int?
  inputImages      Int?
  inputAudioS      Float?
  durationMs       Int?
  fileSizeBytes    BigInt?
  estimatedCostUsd Float    @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([jobId])
  @@index([createdAt])
}

model JobLog {
  id          String   @id @default(cuid())
  feedVideoId String
  feedVideo   FeedVideo @relation(fields: [feedVideoId], references: [id], onDelete: Cascade)
  jobType     String   // transcription | speaker-transcription | clip-generation | download
  status      String   // queued | started | completed | failed
  message     String?
  error       String?  @db.Text
  durationMs  Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([feedVideoId])
  @@index([jobType])
  @@index([status])
  @@index([createdAt])
}

model UploadLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage        String   // initiate | part-url | part-upload | complete-multipart | register | from-url
  status       String   // started | success | failed
  filename     String?
  key          String?
  uploadId     String?
  partNumber   Int?
  fileSize     Int?
  contentType  String?
  durationMs   Int?
  error        String?  @db.Text
  metadata     Json?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([stage])
  @@index([status])
  @@index([createdAt])
  @@index([uploadId])
}

model ClipCropTemplate {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  aspectRatio String
  cropX      Float
  cropY      Float
  cropWidth  Float
  cropHeight Float
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model AutomationRule {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  enabled          Boolean  @default(false)
  autoGenerateClips Boolean @default(true)
  viralitySettings Json?
  captionsEnabled  Boolean  @default(true)
  captionStyle     String   @default("default")
  aspectRatio      String   @default("9:16")
  cropTemplateId   String?
  autoPublish      Boolean  @default(false)
  publishPlatforms Json?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TruthAnalysis {
  id               String    @id @default(cuid())
  feedVideoId      String
  feedVideo        FeedVideo @relation(fields: [feedVideoId], references: [id], onDelete: Cascade)
  clipId           String    @default("__video__") // "__video__" = full video; otherwise clip ID
  userId           String
  provider         String    // gemini | ollama
  model            String?
  status           String    @default("pending") // pending | processing | completed | failed
  error            String?   @db.Text
  result           Json?     // TruthAnalysisResult
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostUsd Float?
  durationMs       Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([feedVideoId, clipId])
  @@index([feedVideoId])
  @@index([userId])
}

model TrainingExample {
  id                  String   @id @default(cuid())
  userId              String
  jobId               String   // feedVideoId
  provider            String   // gemini | ollama
  model               String?  // e.g. models/gemini-2.5-flash

  // Input
  transcriptText      String   @db.Text
  tStartS             Float
  tEndS               Float
  targetPlatform      String   @default("all")
  contentStyle        String?
  saferClips          Boolean  @default(false)
  includeAudio        Boolean  @default(false)
  frameCount          Int      @default(0)
  audioSeconds        Float    @default(0)

  // Heuristic pre-score context
  heuristicScore      Float?
  heuristicFeatures   Json?

  // LLM output (raw scores before aggregation)
  llmScore            Float
  hookScore           Float?
  contextScore        Float?
  captionabilityScore Float?
  comedicScore        Float?
  provocativeScore    Float?
  visualEnergyScore   Float?
  audioEnergyScore    Float?
  riskScore           Float?
  riskFlags           Json?    // string[]
  hasViralMoment      Boolean?
  confidence          Float?
  rationale           String?  @db.Text

  // Post-aggregation
  finalScore          Float    // after platform weights + safety penalty
  wasSelected         Boolean  @default(false) // made it into final clip set

  // Cost metadata
  inputTokens         Int?
  outputTokens        Int?
  estimatedCostUsd    Float?
  durationMs          Int?

  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([jobId])
  @@index([provider])
  @@index([confidence])
  @@index([createdAt])
}

model TruthTrainingExample {
  id               String   @id @default(cuid())
  userId           String
  feedVideoId      String
  provider         String   // gemini | ollama
  model            String?
  type             String   // analysis | chat

  // Input
  transcriptText   String   @db.Text
  analysisContext   Json?    // for chat: the TruthAnalysisResult used as context
  conversationHistory Json?  // for chat: prior messages array

  // Output
  result           Json     // analysis: TruthAnalysisResult, chat: { content: string }

  // Quality signals
  overallCredibility Float?  // from analysis result (0-10)
  assertionCount   Int?
  fallacyCount     Int?
  biasCount        Int?

  // Cost metadata
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostUsd Float?
  durationMs       Int?

  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([feedVideoId])
  @@index([provider])
  @@index([type])
  @@index([createdAt])
}

model AnalysisChat {
  id              String   @id @default(cuid())
  feedVideoId     String
  feedVideo       FeedVideo @relation(fields: [feedVideoId], references: [id], onDelete: Cascade)
  clipId          String   @default("__video__")
  userId          String
  provider        String   // gemini | ollama
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        AnalysisChatMessage[]

  @@unique([feedVideoId, clipId])
  @@index([userId])
}

model AnalysisChatMessage {
  id               String   @id @default(cuid())
  chatId           String
  chat             AnalysisChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role             String   // user | assistant
  content          String   @db.Text
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostUsd Float?
  durationMs       Int?
  createdAt        DateTime @default(now())

  @@index([chatId])
}

model Publication {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  tagline               String?
  configMarkdown        String    @db.Text
  configJson            Json?
  substackUrl           String?
  substackConnected     Boolean   @default(false)
  substackCookieEnc     String?
  substackPublicationId String?
  isDefault             Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  articles              Article[]

  @@index([userId])
  @@unique([userId, name])
}

model Article {
  id               String    @id @default(cuid())
  publicationId    String
  publication      Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  userId           String
  title            String
  subtitle         String?
  bodyMarkdown     String?   @db.Text
  bodyHtml         String?   @db.Text
  sourceType       String?
  sourceId         String?
  sourceContext     Json?
  generationModel  String?
  status           String    @default("draft")
  substackDraftId  String?
  substackPostId   String?
  publishError     String?
  publishedAt      DateTime?
  tags             Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  graphics         ArticleGraphic[]
  publishes        ArticlePublish[]

  @@index([publicationId])
  @@index([userId])
}

model ArticleGraphic {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type        String
  label       String?
  htmlContent String?  @db.Text
  s3Key       String?
  s3Url       String?
  config      Json?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articleId])
}

model PublishingAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String
  displayName       String
  subdomain         String?
  platformUrl       String?
  platformAccountId String?
  credentialEnc     String?
  connected         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  publishes         ArticlePublish[]

  @@index([userId])
}

model ArticlePublish {
  id                  String   @id @default(cuid())
  articleId           String
  article             Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  publishingAccountId String
  publishingAccount   PublishingAccount @relation(fields: [publishingAccountId], references: [id], onDelete: Cascade)
  platformDraftId     String?
  platformPostId      String?
  platformUrl         String?
  status              String   @default("draft")
  publishError        String?
  publishedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([articleId])
  @@index([publishingAccountId])
  @@unique([articleId, publishingAccountId])
}

model SocialPost {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  platforms  Json     // string[] of platforms this post was sent to
  status     String   @default("pending") // pending | publishing | completed | failed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  publishes  SocialPostPublish[]

  @@index([userId])
  @@index([createdAt])
}

model SocialPostPublish {
  id             String    @id @default(cuid())
  socialPostId   String
  socialPost     SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  platform       String    // twitter | facebook | bluesky | threads
  status         String    @default("pending") // pending | published | failed
  platformPostId String?
  platformUrl    String?
  publishError   String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([socialPostId])
  @@index([platform])
  @@unique([socialPostId, platform])
}

model Composition {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  mode             String   @default("pre-synced") // pre-synced | timeline
  status           String   @default("draft") // draft | rendering | completed | failed
  audioMode        String   @default("creator") // creator | reference | both
  creatorVolume    Float    @default(1.0)
  referenceVolume  Float    @default(1.0)
  creatorS3Key     String?
  creatorS3Url     String?
  creatorDurationS    Float?
  creatorWidth        Int?
  creatorHeight       Int?
  creatorTrimStartS   Float    @default(0)
  creatorTrimEndS     Float?
  creatorTranscript      String?  @db.Text
  creatorTranscriptJson  Json?
  cuts                    Json?    // Array<{ id: string; startS: number; endS: number; targets: string[] }>
  thumbnailCutoutPosition String  @default("right") // left | right
  thumbnailCutoutSize     String  @default("large")  // small | medium | large
  createdAt           DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tracks           CompositionTrack[]
  outputs          CompositionOutput[]
  thumbnails       CompositionThumbnail[]
  thumbnailAssets  ThumbnailAsset[]

  @@index([userId])
  @@index([status])
}

model CompositionTrack {
  id            String      @id @default(cuid())
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  label         String?
  s3Key         String
  s3Url         String
  durationS     Float
  width         Int?
  height        Int?
  startAtS      Float       @default(0)
  trimStartS    Float       @default(0)
  trimEndS      Float?
  sortOrder     Int         @default(0)
  hasAudio      Boolean     @default(true)
  transcript    String?     @db.Text
  transcriptJson Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([compositionId])
}

model CompositionOutput {
  id            String      @id @default(cuid())
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  layout        String      // mobile | landscape
  s3Key         String?
  s3Url         String?
  status        String      @default("pending") // pending | rendering | completed | failed
  renderError   String?     @db.Text
  durationMs    Int?
  fileSizeBytes BigInt?
  transcript    String?     @db.Text
  transcriptJson Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([compositionId])
}

model CompositionThumbnail {
  id              String      @id @default(cuid())
  compositionId   String
  composition     Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  s3Key           String
  s3Url           String
  hookText        String
  frameTimestampS Float
  visionScore     Float?
  selected        Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([compositionId])
}

model ThumbnailAsset {
  id              String      @id @default(cuid())
  compositionId   String
  composition     Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  type            String      // "reference" | "cutout"
  s3Key           String
  s3Url           String
  frameTimestampS Float
  visionScore     Float?
  createdAt       DateTime    @default(now())

  @@index([compositionId, type])
}
