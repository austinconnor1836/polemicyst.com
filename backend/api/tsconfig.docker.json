{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@prisma/client": ["./node_modules/@prisma/client"]
    }
  },
  "include": ["**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules"]
}
