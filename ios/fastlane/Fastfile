require 'json'

default_platform(:ios)

XCODEPROJ = "Polemicyst.xcodeproj"
SCHEME = "PolemicystApp"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Run tests"
  lane :test do
    run_tests(
      project: XCODEPROJ,
      scheme: SCHEME,
      device: "iPhone 16",
      clean: true
    )
  end

  desc "Build and upload to TestFlight (dev)"
  lane :beta do
    setup_signing
    set_build_number
    set_marketing_version

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: "API_BASE_URL='https://dev.polemicyst.com' DEVELOPMENT_TEAM='#{ENV["APPLE_TEAM_ID"]}'",
      output_directory: "./build",
      output_name: "Polemicyst.ipa"
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build and upload to App Store Connect (prod)"
  lane :release do
    setup_signing
    set_build_number
    set_marketing_version

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: "DEVELOPMENT_TEAM='#{ENV["APPLE_TEAM_ID"]}'",
      output_directory: "./build",
      output_name: "Polemicyst.ipa"
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true
    )
  end

  # ------------------------------------------------------------------
  # Helpers
  # ------------------------------------------------------------------

  private_lane :setup_signing do
    # Create a temporary keychain for CI
    keychain_name = "ci_signing.keychain-db"
    keychain_password = SecureRandom.hex(16)

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )

    # Import distribution certificate
    import_certificate(
      certificate_path: "fastlane/cert.p12",
      certificate_password: ENV["APPLE_CERTIFICATE_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    # Install provisioning profile
    install_provisioning_profile(
      path: "fastlane/profile.mobileprovision"
    )

    update_project_provisioning(
      xcodeproj: XCODEPROJ,
      profile: "fastlane/profile.mobileprovision",
      target_filter: "PolemicystApp",
      build_configuration: "Release",
      code_signing_identity: "Apple Distribution"
    )
  end

  private_lane :set_build_number do
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"
    increment_build_number(
      build_number: build_number,
      xcodeproj: XCODEPROJ
    )
  end

  private_lane :set_marketing_version do
    version_file = File.join(Dir.pwd, "..", "..", "version.json")
    if File.exist?(version_file)
      version_data = JSON.parse(File.read(version_file))
      version = version_data["version"]
      increment_version_number(
        version_number: version,
        xcodeproj: XCODEPROJ
      )
      UI.message("Set MARKETING_VERSION to #{version} from version.json")
    else
      UI.important("version.json not found, keeping default MARKETING_VERSION")
    end
  end

  desc "Submit latest build for App Store review"
  lane :promote do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: ENV["AUTO_RELEASE"] == "true",
      phased_release: true,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
